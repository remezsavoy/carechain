# Secret key used for JWT token signing and verification.
JWT_SECRET=your_jwt_secret_here

# The deployed contract address on the blockchain.
CONTRACT_ADDRESS=0xYourDeployedContractAddress

# Private key associated with a wallet or account.
PRIVATE_KEY=0xYourPrivateKey

# Local RPC URL for interacting with the Ganache blockchain instance.
GANACHE_RPC_URL=http://127.0.0.1:7545
